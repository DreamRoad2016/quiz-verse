{
  "workId": "zhenhuan_2011",
  "titleCn": "甄嬛传",
  "description": "录入页与比对列的字段定义；选项内容在 enums/*.json 中维护，可增删改。",
  "character": {
    "displayName": {
      "label": "姓名",
      "storage": "column",
      "column": "display_name",
      "required": true,
      "compare": false,
      "hint": "库中规范名，猜局联想主显示"
    },
    "callNames": {
      "label": "称呼",
      "storage": "column",
      "column": "call_names",
      "selectMode": "tags",
      "required": false,
      "compare": false,
      "hint": "旁人怎么叫 TA：嬛嬛、熹贵妃等；不是位分，位分在 titles"
    }
  },
  "attrs": [
    {
      "key": "gender",
      "label": "性别",
      "selectMode": "single",
      "enumFile": "enums/gender.json",
      "required": true,
      "compare": true,
      "compareRule": "exact"
    },
    {
      "key": "role_type",
      "label": "身份类别",
      "selectMode": "single",
      "enumFile": "enums/role_type.json",
      "required": true,
      "compare": true,
      "compareRule": "exact"
    },
    {
      "key": "titles",
      "label": "位分",
      "selectMode": "multi",
      "enumFile": "enums/titles.json",
      "required": true,
      "compare": true,
      "compareRule": "set_overlap",
      "hint": "经历过的册封/职分，可多选；与称呼无关"
    },
    {
      "key": "residences",
      "label": "住所",
      "selectMode": "multi",
      "enumFile": "enums/residences.json",
      "required": true,
      "compare": true,
      "compareRule": "set_overlap"
    },
    {
      "key": "major_plots",
      "label": "重大剧情",
      "selectMode": "multi",
      "enumFile": "enums/major_plots.json",
      "required": false,
      "compare": true,
      "compareRule": "set_overlap",
      "hint": "出场过的名场面，选项在 major_plots.json 配置；存 attrs 中的 key 数组"
    },
    {
      "key": "connections",
      "label": "关系网",
      "selectMode": "multi",
      "refType": "character",
      "required": false,
      "compare": true,
      "compareRule": "set_overlap",
      "hint": "选其他角色 id，多选"
    }
  ]
}
